    { "label": "spinning_joke" },
    { "bg": "neon_arcade" },
    { "speaker": "lamp", "expression": "", "text": "重たい言葉も、光る記号になると急に軽く回り始めます。" },
    { "speaker": "waddy", "expression": "", "text": "笑っていいのか分からないのに、頭には残るんだよな。" },
    { "choices": [ { "text": "光る冗談を持ち帰る", "goto": "END_JOKE" }, { "text": "声の合流点へ向かう", "goto": "mitra_gate" } ] },
    { "label": "body_anchor" },
    { "bg": "city_night" },
    { "speaker": "body", "expression": "", "text": "頭の中で回ったものは、最後に胃の熱へ降りてきました。" },
    { "speaker": "narrator", "expression": "", "text": "外出の記録が、一日の錨になる。" },
    { "choices": [ { "text": "身体の錨を持ち帰る", "goto": "END_BODY" }, { "text": "声の合流点へ向かう", "goto": "mitra_gate" } ] },
    { "label": "mitra_gate" },
    { "bg": "chorus_morning" },
    { "speaker": "mitra", "expression": "", "text": "頭の赤い光と、胃に落ちる赤い熱。別の回路が、同じ夜で閉じました。" },
    { "choices": [ { "text": "丼へ戻る", "goto": "END_BOWL" }, { "text": "冗談へ戻る", "goto": "END_JOKE" }, { "text": "身体へ戻る", "goto": "END_BODY" } ] },
    { "label": "END_BOWL" },
    { "bg": "ramen_counter" },
    { "speaker": "narrator", "expression": "", "text": "赤いスープの熱が、考えすぎた頭を現在地へ戻した。\n──END: 赤い熱" },
