  "scenario": [
    { "label": "standalone_start" },
    { "bg": "city_night" },
    { "speaker": "narrator", "expression": "", "text": "赤い冗談が頭の中で回り、町田の夜には赤い湯気が立っていた。" },
    { "speaker": "waddy", "expression": "", "text": "今日は、頭の光を胃の熱で終わらせる日かもしれない。" },
    { "label": "choose_red" },
